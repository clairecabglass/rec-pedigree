generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Horse {
  id        String    @id @default(cuid())
  microchip String?
  name      String    @unique
  breed     String?
  gender    String?
  sireName  String?
  damName   String?
  coat      String?
  withFoal  Boolean   @default(false)
  ownership String?
  notes     String?
  dob       DateTime?

  // Richer profile fields
  height       String?
  discipline   String?
  regNumber    String?
  achievements String?
  videoUrl     String?
  personality  String?
  genotype     String?
  eyeColor     String?
  baseStats    String?
  description  String? // backstory

  // Owner / roleplay info
  ownerName      String? // Discord name
  ownerCharacter String? // in-game character
  stablePrefix   String?

  // Breeding
  breedingFee      String?
  breedingPolicies String?

  // For Sale details
  price           String?
  saleDescription String?
  saleContact     String?

  photos    Photo[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Photo {
  id        String   @id @default(cuid())
  horseId   String
  horse     Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  url       String
  key       String
  caption   String?
  order     Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([horseId])
}

model Document {
  id        String   @id @default(cuid())
  horseId   String
  horse     Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  url       String
  key       String
  label     String
  type      String?
  createdAt DateTime @default(now())

  @@index([horseId])
}

// Editable site content (homepage text, announcements, future pages)
model SiteContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
